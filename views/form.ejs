<%- include("partials/header") %>

<section class="w50">

<form method="POST" action="/submit">

<label>Name</label>
<input type="text" name="name" value="<%= values.name || '' %>"><br/>

<label>Email</label>
<input type="email" name="email" value="<%= values.email || '' %>"><br/>

<label>Phone</label>
<input type="text" name="phone" value="<%= values.phone || '' %>"><br/>

<label>Post Code</label>
<input type="text" name="postcode" value="<%= values.postcode || '' %>"><br/>

<label>Will you have lunch?</label>

<input type="radio" name="lunch" value="yes"
<%= values.lunch === "yes" ? "checked" : "" %>>
Yes

<input type="radio" name="lunch" value="no"
<%= values.lunch === "no" ? "checked" : "" %>>
No

<br/>

<label>Number of Tickets</label>

<select name="tickets">

    <option value="">
        ----- Select -----
    </option>

    <option value="1"
    <%= values.tickets == "1" ? "selected" : "" %>>
        1
    </option>

    <option value="2"
    <%= values.tickets == "2" ? "selected" : "" %>>
        2
    </option>

    <option value="3"
    <%= values.tickets == "3" ? "selected" : "" %>>
        3
    </option>

</select>

<br/>

<label>Which Campus?</label>

<select name="campus">

    <option value="">
        ----- Select -----
    </option>

    <option value="Doon"
    <%= values.campus == "Doon" ? "selected" : "" %>>
        Doon
    </option>

    <option value="Waterloo"
    <%= values.campus == "Waterloo" ? "selected" : "" %>>
        Waterloo
    </option>

    <option value="Cambridge"
    <%= values.campus == "Cambridge" ? "selected" : "" %>>
        Cambridge
    </option>

</select>

<br/><br/>

<input type="submit" value="Submit">

<p id="errors">
<% errors.forEach(function(error){ %>
    <%= error %><br/>
<% }) %>
</p>

</form>

</section>

<section class="w50">
    <div class="formData">
        <p>Please complete the form.</p>
    </div>
</section>

<div class="clear"></div>

<%- include("partials/footer") %>